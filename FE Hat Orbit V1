local plr = game.Players.LocalPlayer;
local chatService = game:GetService("TextChatService");
local generalChannel = chatService.TextChannels.RBXGeneral;
local UserInputService = game:GetService("UserInputService");
local RunService = game:GetService("RunService");

local mov = {}; 
local mov2 = {}; 

-- ** PATTERN VARIABLES **
local rotx = 0;
local rotz = math.pi / 2;
local height = 0;
local heighti = 1;
local offset = 30;              
local speed = 50;               
local mode = 1;                 
local angular = Vector3.new(0, 80, 0); 
local l = 1;
local waveFactor = 0;           

local function getNumAccessories()
    return math.max(1, #mov);
end

-- ** 1. INPUT PARSER FUNCTION (KEYBOARD) **
local function handleInput(input, gameProcessedEvent)
    if gameProcessedEvent then return end

    local key = input.KeyCode;
    local new_mode = nil;

    -- KEYS 1-0 (Modes 1-10: Geometric & Knots)
    if key == Enum.KeyCode.One then new_mode = 1;    -- Superellipse Orbit
    elseif key == Enum.KeyCode.Two then new_mode = 2;  -- Hypocycloid / Spirograph
    elseif key == Enum.KeyCode.Three then new_mode = 3;  -- Torus Knot (p=5, q=3)
    elseif key == Enum.KeyCode.Four then new_mode = 4;   -- Dynamic Tetrahedron 
    elseif key == Enum.KeyCode.Five then new_mode = 5;   -- Attractor Warp Field 
    elseif key == Enum.KeyCode.Six then new_mode = 6;   -- Epitrochoid Curve (New)
    elseif key == Enum.KeyCode.Seven then new_mode = 7; -- Rose Curve (New)
    elseif key == Enum.KeyCode.Eight then new_mode = 8;  -- Lissajous Knot (7, 5, 6)
    elseif key == Enum.KeyCode.Nine then new_mode = 9;  -- Fibonacci Spiral
    elseif key == Enum.KeyCode.Zero then new_mode = 10; -- Hypersphere Projector

    -- KEYS F1-F12 (Modes 11-22: Dynamic & Volumetric)
    elseif key == Enum.KeyCode.F1 then new_mode = 11; -- Double Helix Orbit (New)
    elseif key == Enum.KeyCode.F2 then new_mode = 12; -- Volumetric Orbit
    elseif key == Enum.KeyCode.F3 then new_mode = 13; -- Vortex Turbine
    elseif key == Enum.KeyCode.F4 then new_mode = 14; -- Concentric Rings (Stacked)
    elseif key == Enum.KeyCode.F5 then new_mode = 15; -- Breathing Cone 
    elseif key == Enum.KeyCode.F6 then new_mode = 16; -- Ribbon Wave
    elseif key == Enum.KeyCode.F7 then new_mode = 17; -- Stacked Pulsing Rings
    elseif key == Enum.KeyCode.F8 then new_mode = 18; -- Spherical Shell (Moire Effect)
    elseif key == Enum.KeyCode.F9 then new_mode = 19; -- Hyperbolic Warp Pulse
    elseif key == Enum.KeyCode.F10 then new_mode = 20; -- Wavefront Emitter
    elseif key == Enum.KeyCode.F11 then new_mode = 21; -- Chaos Cube (New high-impact mode)
    elseif key == Enum.KeyCode.F12 then new_mode = 22; -- Galactic Swarm (New high-impact mode)
    end

    if new_mode then
        mode = new_mode;
    end
end

UserInputService.InputBegan:Connect(handleInput);


-- Function containing everything that must run ONCE at the start of the script.
